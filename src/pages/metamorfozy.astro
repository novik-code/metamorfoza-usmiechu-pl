---
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import { site } from '../data/site';

const faqItems = [
  {
    q: 'Ile kosztuje metamorfoza uśmiechu?',
    a: 'Zależy od zakresu i metod: od pojedynczych licówek czy wybielania po pełny makeover na 8–10 licówkach lub koronach. Koszt obejmuje projekt uśmiechu (DSD), prace tymczasowe i docelowe oraz materiał (np. porcelana, cyrkon). Realny, indywidualny kosztorys przedstawiamy po badaniu — przed rozpoczęciem leczenia.',
  },
  {
    q: 'Czy trzeba szlifować zęby pod licówki?',
    a: 'Zakres szlifowania zależy od sytuacji i wybranej techniki — bywa minimalny, a w wybranych przypadkach możliwe są licówki o bardzo oszczędnym opracowaniu. O zakresie decyduje stan zębów i zaplanowany efekt; omawiamy go na etapie projektu uśmiechu.',
  },
  {
    q: 'Czy licówki zniszczą moje zęby?',
    a: 'Prawidłowo zaplanowane i wykonane licówki nie „niszczą” zębów — chronią je i poprawiają estetykę. Kluczowa jest właściwa kwalifikacja (stan zębów, dziąseł i zgryzu) oraz precyzja wykonania. Dlatego metamorfozę poprzedza dokładna analiza.',
  },
  {
    q: 'Ile wytrzymują licówki porcelanowe?',
    a: 'Przy dobrej higienie i regularnych kontrolach licówki porcelanowe służą zwykle wiele lat — często ponad 10. Żywotność skracają m.in. bruksizm (zgrzytanie), urazy i zaniedbania higieniczne; w razie potrzeby pojedynczą licówkę można wymienić.',
  },
  {
    q: 'Porcelana czy kompozyt — co wybrać?',
    a: 'Licówki kompozytowe są tańsze i szybsze, ale mniej trwałe i bardziej podatne na przebarwienia; porcelanowe (np. e.max) są trwalsze, stabilniejsze kolorystycznie i bardziej naturalne optycznie. Wybór zależy od oczekiwań, budżetu i stanu wyjściowego.',
  },
  {
    q: 'Czy efekt wygląda naturalnie?',
    a: 'Tak — celem jest uśmiech dopasowany do Twojej twarzy, a nie identyczne, oślepiająco białe „klocki”. Kształt, długość i kolor dobieramy indywidualnie, a cyfrowy projekt uśmiechu (DSD) i mock-up pozwalają zobaczyć efekt jeszcze przed leczeniem.',
  },
];

const medicalSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': `${site.url}/metamorfozy#webpage`,
  url: `${site.url}/metamorfozy`,
  name: 'Metamorfoza uśmiechu — smile makeover',
  inLanguage: 'pl-PL',
  lastReviewed: '2026-06-01',
  author: { '@id': site.author.canonicalId },
  about: {
    '@type': 'MedicalProcedure',
    name: 'Metamorfoza uśmiechu (smile makeover)',
    howPerformed:
      'Kompleksowa zmiana estetyki zębów łącząca metody dobrane indywidualnie: cyfrowy projekt uśmiechu (DSD), licówki, korony pełnoceramiczne, wybielanie, czasem korekta dziąseł i leczenie wstępne.',
    bodyLocation: 'Zęby przednie (strefa estetyczna)',
  },
};
---

<BaseLayout
  title="Metamorfozy uśmiechu — co realnie da się osiągnąć"
  description="Metamorfoza uśmiechu — na czym polega, jakimi metodami (licówki, korony, wybielanie, DSD), co realnie można osiągnąć i w jakim czasie. Naturalny efekt zamiast „sztucznego”. Przewodnik dr Nowosielskiego, M.Sc."
>
  <section class="mu-masthead">
    <div class="container">
      <p class="mu-overline">Przewodnik · metamorfozy</p>
      <h1>Metamorfoza uśmiechu — co to jest i co da się osiągnąć</h1>
      <p class="lead">
        Metamorfoza uśmiechu (smile makeover) to <strong>kompleksowa zmiana estetyki
        zębów</strong> — kształtu, koloru, proporcji i harmonii z twarzą — z użyciem
        kilku metod dobranych do Twojej sytuacji.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={site.clinic.bookingUrl} rel="noopener">Zaprojektuj swój uśmiech →</a>
      </div>
    </div>
  </section>

  <section class="container">
    <h2 class="ba-heading">Przykładowa realizacja — przed i po</h2>
    <div class="beforeafter">
      <figure>
        <span class="ba-label ba-label--before">Przed</span>
        <img src="/realizacje/metamorfoza-1-przed.webp" alt="Uśmiech przed metamorfozą — starte, przebarwione i nierówne zęby, widoczne ubytki przed leczeniem" loading="lazy" width="920" height="920" />
      </figure>
      <figure>
        <span class="ba-label ba-label--after">Po</span>
        <img src="/realizacje/metamorfoza-1-po.webp" alt="Uśmiech po metamorfozie — równe, naturalnie białe zęby po kompleksowej odbudowie estetycznej pełnego łuku" loading="lazy" width="920" height="920" />
      </figure>
    </div>
    <p class="ba-caption">
      Rzeczywista metamorfoza wykonana przez lek. dent. Marcina Nowosielskiego w klinice
      <a href="https://mikrostomart.pl" rel="noopener">Mikrostomart</a> — kompleksowa odbudowa estetyczna
      pełnego łuku. <strong>Efekty leczenia są indywidualne</strong> i zależą od stanu wyjściowego;
      każdy przypadek wymaga osobnej kwalifikacji i planu.
    </p>
    <p style="text-align:center; margin-top:1rem;">
      <a class="btn-outline" href="/realizacje">Zobacz wszystkie 16 realizacji przed/po →</a>
    </p>
  </section>

  <section class="container prose">
    <h2>Co składa się na metamorfozę</h2>
    <p>
      Rzadko jest to jedna procedura — najczęściej <strong>przemyślane połączenie</strong>:
    </p>
    <ul>
      <li><strong><a href="/projekt-usmiechu-dsd">Projekt uśmiechu (DSD)</a></strong> — punkt wyjścia: cyfrowy projekt i mock-up,</li>
      <li><strong><a href="/licowki">Licówki</a></strong> — kształt, kolor, zamknięcie szpar, korekta drobnych nierówności,</li>
      <li><strong>Korony pełnoceramiczne</strong> — gdy ząb jest mocno zniszczony,</li>
      <li><strong><a href="/wybielanie">Wybielanie</a></strong> — często pierwszy, najmniej inwazyjny krok,</li>
      <li>czasem <strong>korekta dziąseł</strong> lub wcześniejsze leczenie (próchnica, zgryz).</li>
    </ul>

    <h2>Co realnie da się osiągnąć</h2>
    <ul>
      <li>jaśniejszy, równy kolor,</li>
      <li>regularny kształt i proporcje zębów,</li>
      <li>zamknięcie szpar i drobnych nierówności,</li>
      <li>odbudowa startych/ukruszonych brzegów,</li>
      <li>harmonijna linia uśmiechu dopasowana do twarzy.</li>
    </ul>

    <div class="callout">
      <strong>Naturalnie, nie „sztucznie".</strong> Cel to uśmiech, który pasuje do Twojej
      twarzy — a nie identyczne, oślepiająco białe „klocki". Kształt, długość i kolor
      dobieramy indywidualnie; pomaga w tym <a href="/projekt-usmiechu-dsd">cyfrowy projekt uśmiechu</a>.
    </div>

    <h2>Jak przebiega — etapy</h2>
    <ol>
      <li><strong>Konsultacja i analiza</strong> — zdjęcia, ocena zębów, dziąseł i zgryzu.</li>
      <li><strong>Projekt uśmiechu (DSD)</strong> — cyfrowa wizualizacja i mock-up do akceptacji.</li>
      <li><strong>Przygotowanie</strong> — w razie potrzeby leczenie zachowawcze/higienizacja, wybielanie.</li>
      <li><strong>Realizacja</strong> — licówki / korony wg projektu.</li>
      <li><strong>Dopasowanie i kontrola</strong> — finalna korekta koloru i kształtu.</li>
    </ol>

    <h2>Ile to trwa</h2>
    <p>
      W zależności od zakresu — od jednej-dwóch wizyt (wybielanie, pojedyncze licówki)
      po kilka tygodni przy pełnym makeoverze. Najpierw projekt, potem realizacja —
      dzięki temu efekt jest <strong>przewidywalny</strong>.
    </p>

    <h2>Od czego zależy efekt</h2>
    <p>
      Od stanu wyjściowego (zęby, dziąsła, zgryz), wybranych metod i materiałów.
      Czasem metamorfozę poprzedza leczenie (np. próchnicy lub stłoczeń). Realny,
      indywidualny plan przedstawiamy po badaniu — wraz z <a href="/cennik">kosztem</a>.
    </p>
  </section>

  <Faq items={faqItems} heading="Metamorfoza uśmiechu — najczęstsze pytania" />

  <script type="application/ld+json" set:html={JSON.stringify(medicalSchema)} />

  <section class="mu-callout">
    <div class="container">
      <h2>Zobaczmy Twój nowy uśmiech — zanim cokolwiek zaczniemy</h2>
      <p>
        Prześlij zdjęcie uśmiechu lub umów wizytę — przygotujemy projekt i plan
        metamorfozy z wariantami i kosztem. Pacjentów przyjmujemy z całej Polski.
      </p>
      <a class="btn-primary" href={site.clinic.bookingUrl} rel="noopener">Umów bezpłatną konsultację →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .case-figure { margin: 0; }
  .case-figure img { width: 100%; height: auto; border-radius: 10px; box-shadow: 0 6px 24px rgba(58,39,51,0.12); display: block; }
  .case-figure figcaption { font-size: 0.8125rem; color: var(--color-muted); text-align: center; margin-top: 0.5rem; font-style: italic; }

  .ba-heading { text-align: center; margin-bottom: 1.25rem; }
  .beforeafter {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    max-width: 760px; margin: 0 auto;
  }
  .beforeafter figure { position: relative; margin: 0; }
  .beforeafter img {
    width: 100%; height: auto; display: block; border-radius: 10px;
    box-shadow: 0 6px 24px rgba(58,39,51,0.12);
  }
  .ba-label {
    position: absolute; top: 0.75rem; left: 0.75rem;
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.25rem 0.625rem; border-radius: 999px; color: #fff;
  }
  .ba-label--before { background: rgba(28,29,32,0.78); }
  .ba-label--after { background: var(--color-accent, #b06a86); }
  .ba-caption {
    max-width: 760px; margin: 0.9rem auto 0; text-align: center;
    font-size: 0.8125rem; color: var(--color-muted); font-style: italic; line-height: 1.6;
  }
  @media (max-width: 520px) { .beforeafter { grid-template-columns: 1fr; } }
</style>
