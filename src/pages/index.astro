---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { getCollection } from 'astro:content';
import { categoryMeta, formatDate } from '../utils/categories';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = allPosts.slice(0, 4);
---

<BaseLayout>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Metamorfoza uśmiechu · licówki · DSD · cała Polska</p>
      <h1>Metamorfoza uśmiechu — Twój nowy, naturalny uśmiech</h1>
      <p class="lead">
        Przebarwione, starte, nierówne czy ukruszone zęby da się zmienić w
        <strong>harmonijny, naturalny uśmiech</strong> — licówkami, koronami, wybielaniem
        i cyfrowym projektem uśmiechu (DSD), dzięki któremu <strong>widzisz efekt zanim
        cokolwiek zaczniemy</strong>. Niezależny przewodnik przygotowuje
        <strong>{site.author.honorificPrefix} {site.author.name}, {site.author.honorificSuffix} RWTH Aachen</strong>.
        Leczenie w klinice <a href={site.clinic.url} rel="noopener">Mikrostomart</a> (pacjenci z całej Polski).
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={site.clinic.bookingUrl} rel="noopener">Bezpłatna konsultacja →</a>
        <a class="btn-outline" href="/metamorfozy">Zobacz metamorfozy</a>
      </div>
    </div>
  </section>

  <section class="container">
    <figure class="hero-figure">
      <img src="/metamorfoza-usmiechu-case.jpg" alt="Metamorfoza uśmiechu — efekt przed i po leczeniu estetycznym" loading="lazy" width="1200" height="675" />
      <figcaption>Przykładowa metamorfoza uśmiechu — efekt kompleksowego leczenia estetycznego.</figcaption>
    </figure>
  </section>

  <section class="container">
    <h2>Jak zmieniamy uśmiech</h2>
    <div class="pillar-grid">
      <a href="/projekt-usmiechu-dsd" class="pillar">
        <span class="pillar-num">01</span>
        <h3>Projekt uśmiechu (DSD)</h3>
        <p>Cyfrowy projekt i mock-up — zobacz i zaakceptuj nowy uśmiech, zanim sięgniemy po wiertło.</p>
      </a>
      <a href="/licowki" class="pillar">
        <span class="pillar-num">02</span>
        <h3>Licówki</h3>
        <p>Cienkie, naturalne licówki porcelanowe i kompozytowe — kształt, kolor, harmonia.</p>
      </a>
      <a href="/wybielanie" class="pillar">
        <span class="pillar-num">03</span>
        <h3>Wybielanie</h3>
        <p>Gabinetowe i nakładkowe — bezpiecznie, na zdrowych zębach, z trwałym efektem.</p>
      </a>
      <a href="/metamorfozy" class="pillar">
        <span class="pillar-num">04</span>
        <h3>Metamorfozy</h3>
        <p>Realne przemiany — co da się osiągnąć, jakimi metodami i w jakim czasie.</p>
      </a>
      <a href="/cennik" class="pillar">
        <span class="pillar-num">05</span>
        <h3>Cennik</h3>
        <p>Od czego zależy koszt licówek, koron, wybielania i pełnego makeoveru.</p>
      </a>
      <a href="/o-autorze" class="pillar">
        <span class="pillar-num">06</span>
        <h3>O autorze</h3>
        <p>Dr Marcin Nowosielski, M.Sc. RWTH Aachen — stomatologia estetyczna.</p>
      </a>
    </div>
  </section>

  <section class="container">
    <div class="callout">
      <strong>Naturalnie, nie „sztucznie".</strong> Dobry efekt to harmonia z twarzą —
      a nie „hollywoodzka klocowatość". Dlatego zaczynamy od
      <a href="/projekt-usmiechu-dsd">projektu uśmiechu</a>: wspólnie ustalamy cel,
      który widzisz na mock-upie, zanim cokolwiek jest nieodwracalne.
    </div>
  </section>

  {latestPosts.length > 0 && (
    <section class="container">
      <header class="section-header">
        <h2>Najnowsze artykuły</h2>
        <a class="see-all" href="/blog">Wszystkie →</a>
      </header>
      <ul class="post-grid">
        {latestPosts.map((post) => (
          <li>
            <article>
              <p class="post-meta">
                <span class="category">{categoryMeta[post.data.category].label}</span>
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              </p>
              <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="cta-section">
    <div class="container">
      <h2>Bezpłatna konsultacja — zaprojektujmy Twój nowy uśmiech</h2>
      <p>
        Prześlij zdjęcie uśmiechu lub umów wizytę — ocenimy możliwości, pokażemy
        cyfrowy projekt i przedstawimy plan z wariantami i kosztem.
        Pacjentów przyjmujemy <strong>z całej Polski</strong> w klinice Mikrostomart.
      </p>
      <a class="btn-primary" href={site.clinic.bookingUrl} rel="noopener">Umów bezpłatną konsultację →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-figure { margin: 0 0 1rem; }
  .hero-figure img { width: 100%; height: auto; border-radius: 10px; box-shadow: 0 6px 24px rgba(58,39,51,0.12); display: block; }
  .hero-figure figcaption { font-size: 0.8125rem; color: var(--color-muted); text-align: center; margin-top: 0.5rem; font-style: italic; }
</style>
